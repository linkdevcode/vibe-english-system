# Vercel Postgres / Neon — chuỗi kết nối đầy đủ (sslmode=require)
# Pooled (hay có `-pooler` trong host): dùng cho app / runtime
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.xx.aws.neon.tech:5432/neondb?sslmode=require"

# Direct, không pool (host thường `ep-xxx` không có `-pooler`): dùng cho `prisma migrate` / `migrate deploy` (tránh P1002 advisory lock timeout)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxx.xx.aws.neon.tech:5432/neondb?sslmode=require"

# Ghi chú: CLI Prisma chỉ đọc `.env`; Next.js đọc thêm `.env.local`.
# Chạy các lệnh DB qua npm (`dotenv -c`): `db:push`, `db:migrate`, `db:migrate:deploy`, `db:seed`
# — cascade `.env` + `.env.local`. Đừng gọi thẳng `npx prisma ...` nếu chỉ có `.env.local`.
#
# Neon / Prisma — xử lý nhanh:
# • P1002 (timeout advisory lock): bắt buộc DATABASE_URL_UNPOOLED trong schema → thử `npm run db:migrate:deploy` lại;
#   nếu vẫn lỗi: `npm run db:migrate:deploy:no-lock` (chỉ một tiến trình migrate tại một thời điểm).
# • Schema đã từng tạo bằng `db push`: `migrate deploy` có thể báo P3005 — chạy `npm run db:push`,
#   rồi (một lần) `npm run db:migrate:resolve:add-exercise`; sau đó `db:migrate:deploy` báo „No pending migrations”.
# • P3008 khi resolve: migration đã được ghi nhận trong DB → bỏ qua resolve, chỉ `db:migrate:deploy` và `db:seed`.

# Ký cookie phiên đăng nhập (tối thiểu 16 ký tự)
SESSION_SECRET="thay-bang-chuoi-ngau-nhien-du-dai-toi-thieu-16-ky-tu"
