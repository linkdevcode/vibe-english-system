# Vercel Postgres / Neon — chuỗi kết nối đầy đủ (ssl)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Ghi chú: CLI Prisma chỉ đọc `.env`; Next.js đọc thêm `.env.local`.
# Chạy `npm run db:push` (`dotenv -c`) để cascade `.env` / `.env.local` — đủ cho trường hợp chỉ có `.env.local`.

# Ký cookie phiên đăng nhập (tối thiểu 16 ký tự)
SESSION_SECRET="thay-bang-chuoi-ngau-nhien-du-dai-toi-thieu-16-ky-tu"
