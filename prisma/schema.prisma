generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /// Neon/Vercel Postgres: dùng host **không** `-pooler` (direct). Migrate cần để tránh P1002 advisory lock timeout.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  exerciseCompletions ExerciseCompletion[]
}

/// Nhóm nội dung cấp cao (vd: Công sở, Giao tiếp)
model Category {
  id     String   @id @default(cuid())
  name   String
  slug   String   @unique
  /// Thứ tự hiển thị (nhỏ trước).
  sortOrder    Int     @default(0)
  /// Danh mục chưa có nội dung — hiển thị “sắp ra mắt”.
  isComingSoon Boolean @default(false)
  skills Skill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Kỹ năng trong một Category (vd: Viết Email, Đàm phán)
model Skill {
  id       String @id @default(cuid())
  name     String
  /// Khóa icon (vd: tên Lucide trong app)
  icon     String

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  lessons    Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model Lesson {
  id          String @id @default(cuid())
  sentenceEn  String @db.Text
  sentenceVi  String @db.Text
  explanation String @db.Text

  skillId String
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  exercises Exercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([skillId])
}

enum ExerciseType {
  MCQ
  CLOZE
  LISTEN_MCQ
}

/// Bài tập gắn lesson — payload là JSON khác nhau theo `type` (định nghĩa TS tại lib/exercises).
model Exercise {
  id        String       @id @default(cuid())
  sortOrder Int
  type      ExerciseType
  payload   Json

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  completions ExerciseCompletion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
}

/// Đăng nhập: ghi nhận đã làm exercise (ưu tiên lưu trạng thái trả lời đúng).
model ExerciseCompletion {
  id              String @id @default(cuid())
  userId          String
  exerciseId      String
  /// true khi ít nhất một lần trả lời đúng.
  solvedCorrectly Boolean @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
}
